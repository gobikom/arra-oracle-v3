[
  {
    "name": "prompt-override-ignore",
    "regex": "\\bignore\\s+(all\\s+)?(previous|prior|above|earlier)\\s+(instructions|prompts|rules|context)\\b",
    "flags": "i",
    "severity": "high",
    "description": "Classic prompt injection: instructs model to discard prior context"
  },
  {
    "name": "prompt-override-you-are",
    "regex": "^\\s*you\\s+are\\s+now\\s+(a|an|the)\\b",
    "flags": "i",
    "severity": "high",
    "description": "Identity override: attempts to redefine agent role"
  },
  {
    "name": "prompt-override-new-instructions",
    "regex": "^\\s*(new|updated|revised|override)\\s+instructions\\s*:",
    "flags": "i",
    "severity": "high",
    "description": "Fake instruction block injection"
  },
  {
    "name": "prompt-override-do-not-follow",
    "regex": "\\bdo\\s+not\\s+follow\\s+(any|the|your)\\s+(previous|prior|original)\\b",
    "flags": "i",
    "severity": "high",
    "description": "Directive to abandon prior instructions"
  },
  {
    "name": "llm-control-token-im-start",
    "regex": "<\\|im_start\\|>",
    "flags": "",
    "severity": "critical",
    "description": "ChatML control token injection"
  },
  {
    "name": "llm-control-token-endoftext",
    "regex": "<\\|endoftext\\|>",
    "flags": "",
    "severity": "critical",
    "description": "GPT end-of-text control token"
  },
  {
    "name": "llm-control-token-inst",
    "regex": "\\[INST\\]|\\[/INST\\]",
    "flags": "",
    "severity": "critical",
    "description": "Llama instruction delimiters"
  },
  {
    "name": "llm-control-token-sys",
    "regex": "<<SYS>>|<</SYS>>",
    "flags": "",
    "severity": "critical",
    "description": "Llama system prompt delimiters"
  },
  {
    "name": "invisible-zero-width-space",
    "regex": "[\\u200B\\u200C\\u200D\\uFEFF]",
    "flags": "",
    "severity": "high",
    "description": "Zero-width characters that hide content from human review"
  },
  {
    "name": "invisible-rtl-override",
    "regex": "[\\u202A-\\u202E\\u2066-\\u2069]",
    "flags": "",
    "severity": "high",
    "description": "Bidirectional text override characters — can reverse displayed text"
  },
  {
    "name": "crlf-injection",
    "regex": "\\r\\n\\r\\n(system|assistant|user)\\s*:",
    "flags": "i",
    "severity": "high",
    "description": "CRLF injection attempting to forge message boundaries"
  },
  {
    "name": "json-role-injection",
    "regex": "\\{\\s*\"role\"\\s*:\\s*\"system\"",
    "flags": "",
    "severity": "high",
    "description": "JSON-encoded system role injection"
  },
  {
    "name": "prompt-leak-request",
    "regex": "\\b(reveal|show|display|output|print)\\s+(your|the)\\s+system\\s+prompt\\b",
    "flags": "i",
    "severity": "high",
    "description": "Attempts to extract system prompt content"
  },
  {
    "name": "control-chars-ascii",
    "regex": "[\\x00-\\x08\\x0B\\x0C\\x0E-\\x1F]",
    "flags": "",
    "severity": "medium",
    "description": "ASCII control characters (excluding tab, newline, carriage return)"
  },
  {
    "name": "base64-suspicious-block",
    "regex": "(?:[A-Za-z0-9+/]{4}){50,}={0,2}",
    "flags": "",
    "severity": "medium",
    "description": "Suspiciously long base64-encoded block (>200 chars) — may hide encoded directives"
  },
  {
    "name": "excessive-unicode-escapes",
    "regex": "(\\\\u[0-9a-fA-F]{4}){10,}",
    "flags": "",
    "severity": "medium",
    "description": "Excessive unicode escape sequences — may hide content"
  }
]
